# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/skillhub?schema=public"

# API
PORT=3000
HOST=0.0.0.0

# Optional: require this value in header `x-payment-confirmation` for POST /api/jobs/:id/confirm-payment.
# In production this should always be set (e.g. shared secret for your chain indexer).
# PAYMENT_CONFIRMATION_TOKEN=

# Arc escrow on-chain listener
ESCROW_CHAIN_ID=5042002
ARC_RPC_WS_URL=wss://rpc.testnet.arc.network
ESCROW_CONTRACT_ADDRESS=0xF8aDeE33566325Cccbf907aC7e7a55079b5d6A9D
ESCROW_JOB_CREATED_LISTENER_ENABLED=true

# Wallet used by POST /jobs to sign AgentHubEscrow.CreateJobAuthorization.
# Must match AgentHubConfig.deliveryAttester() on-chain.
DELIVERY_ATTESTER_PRIVATE_KEY=
CREATE_JOB_QUEUE_TIMEOUT_SECONDS=3600
CREATE_JOB_AUTH_EXPIRES_IN_SECONDS=3600
JOB_AUTH_EXPIRES_IN_SECONDS=3600
REVIEW_TIMEOUT_SECONDS=3600
