generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProviderStatus {
  REGISTERED
  ACTIVE
  SUSPENDED
}

enum TrustLevel {
  UNVERIFIED
  VERIFIED
  CERTIFIED
  HOSTED
}

enum ServiceStatus {
  REGISTERED
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum JobStatus {
  CREATED
  FUNDED
  RUNNING
  SUBMITTED
  ACCEPTED
  SETTLED
  FAILED
  EXPIRED
  REFUNDED
  DISPUTED
}

enum EscrowStatus {
  UNFUNDED
  LOCKED
  RELEASED
  REFUNDED
  DISPUTED
}

model Provider {
  provider_id    String         @id @default(cuid())
  name           String
  description    String?
  status         ProviderStatus @default(REGISTERED)
  owner_wallet   String
  payout_wallet  String
  api_base_url   String
  trust_level    TrustLevel     @default(UNVERIFIED)
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt

  services Service[]

  @@index([status])
  @@index([owner_wallet])
}

model Service {
  service_id      String        @id @default(cuid())
  provider_id     String
  provider        Provider      @relation(fields: [provider_id], references: [provider_id], onDelete: Restrict)
  name            String
  description     String?
  service_type    String
  endpoint_path   String
  input_schema    Json?
  output_schema   Json?
  price_usdc      Decimal       @db.Decimal(18, 6)
  timeout_seconds Int           @default(300)
  status          ServiceStatus @default(REGISTERED)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  jobs Job[]

  @@index([provider_id, status])
}

model Job {
  job_id          String    @id @default(cuid())
  user_wallet     String
  service_id      String
  service         Service   @relation(fields: [service_id], references: [service_id], onDelete: Restrict)
  status          JobStatus @default(CREATED)
  input_uri       String?
  input_hash      String?
  output_uri      String?
  output_hash     String?
  created_at      DateTime  @default(now())
  funded_at       DateTime?
  started_at      DateTime?
  submitted_at    DateTime?
  accepted_at     DateTime?
  settled_at      DateTime?
  work_deadline   DateTime?
  review_deadline DateTime?
  error_message   String?

  escrow Escrow?

  @@index([user_wallet, status])
  @@index([service_id])
}

model Escrow {
  escrow_id           String       @id @default(cuid())
  job_id              String       @unique
  job                 Job          @relation(fields: [job_id], references: [job_id], onDelete: Restrict)
  chain_id            Int
  token_address       String
  escrow_contract     String
  amount_usdc         Decimal      @db.Decimal(18, 6)
  platform_fee_usdc   Decimal      @db.Decimal(18, 6)
  provider_payout_usdc Decimal     @db.Decimal(18, 6)
  escrow_status       EscrowStatus @default(UNFUNDED)
  fund_tx_hash        String?
  release_tx_hash     String?
  refund_tx_hash      String?
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  @@index([escrow_status])
  @@index([job_id])
}
