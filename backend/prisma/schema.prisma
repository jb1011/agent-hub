generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProviderStatus {
  REGISTERED
  ACTIVE
  SUSPENDED
}

enum TrustLevel {
  UNVERIFIED
  VERIFIED
  CERTIFIED
  HOSTED
}

enum JobStatus {
  CREATED
  FUNDED
  RUNNING
  SUBMITTED
  ACCEPTED
  SETTLED
  FAILED
  EXPIRED
  REFUNDED
  DISPUTED
}

enum EscrowStatus {
  UNFUNDED
  LOCKED
  RELEASED
  REFUNDED
  DISPUTED
}

model Provider {
  request_id            String         @id
  registry_provider_id  String?        @unique
  metadata_commitment   String?
  name                String
  description         String?
  status              ProviderStatus @default(REGISTERED)
  owner_wallet        String
  signer_wallet       String
  payout_wallet       String
  api_base_url        String
  trust_level         TrustLevel     @default(UNVERIFIED)
  service_type        String
  input_schema        Json?
  output_schema       Json?
  price_usdc          Decimal        @db.Decimal(18, 6)
  max_concurrent_jobs Int
  timeout_seconds     Int            @default(300)
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  jobs Job[]

  @@index([status])
  @@index([owner_wallet])
  @@index([owner_wallet, metadata_commitment])
}

model Job {
  request_id            String    @id @default(cuid())
  job_id                String?   @unique
  user_wallet           String
  provider_request_id   String
  provider              Provider  @relation(fields: [provider_request_id], references: [request_id], onDelete: Restrict)
  status                JobStatus @default(CREATED)
  input                 Json?
  input_hash            String?
  output                Json?
  output_hash           String?
  created_at            DateTime  @default(now())
  funded_at             DateTime?
  started_at            DateTime?
  submitted_at          DateTime?
  accepted_at           DateTime?
  settled_at            DateTime?
  queue_deadline        DateTime?
  work_deadline         DateTime?
  review_deadline       DateTime?
  final_refund_deadline DateTime?
  delivered_at          DateTime?
  delivery_attestation    Json?
  no_delivery_attestation Json?
  no_delivery_attested_at DateTime?
  error_message         String?

  escrow Escrow?

  @@index([user_wallet, status])
  @@index([provider_request_id])
}

model Escrow {
  escrow_id           String       @id @default(cuid())
  request_id          String       @unique
  job                 Job          @relation(fields: [request_id], references: [request_id], onDelete: Restrict)
  chain_id            Int
  token_address       String
  escrow_contract     String
  amount_usdc         Decimal      @db.Decimal(18, 6)
  platform_fee_usdc   Decimal      @db.Decimal(18, 6)
  provider_payout_usdc Decimal     @db.Decimal(18, 6)
  escrow_status       EscrowStatus @default(UNFUNDED)
  fund_tx_hash        String?
  release_tx_hash     String?
  refund_tx_hash      String?
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  @@index([escrow_status])
  @@index([request_id])
}

model AuthChallenge {
  id             String    @id
  wallet_address String
  chain_id       BigInt    @db.BigInt
  nonce          String    @unique
  domain         String
  uri            String
  statement      String
  issued_at      DateTime  @db.Timestamptz
  expires_at     DateTime  @db.Timestamptz
  consumed_at    DateTime? @db.Timestamptz
  created_at     DateTime  @default(now()) @db.Timestamptz

  @@index([wallet_address])
  @@map("auth_challenges")
}

model User {
  id             String        @id
  wallet_address String        @unique
  status         String        @default("ACTIVE")
  created_at     DateTime      @default(now()) @db.Timestamptz
  updated_at     DateTime      @default(now()) @updatedAt @db.Timestamptz
  sessions       UserSession[]

  @@map("users")
}

model UserSession {
  id                 String    @id
  user_id            String
  user               User      @relation(fields: [user_id], references: [id], onDelete: Restrict)
  refresh_token_hash String    @unique
  created_at         DateTime  @default(now()) @db.Timestamptz
  expires_at         DateTime  @db.Timestamptz
  revoked_at         DateTime? @db.Timestamptz
  last_used_at       DateTime? @db.Timestamptz
  user_agent         String?
  ip_hash            String?

  @@index([user_id])
  @@map("user_sessions")
}
