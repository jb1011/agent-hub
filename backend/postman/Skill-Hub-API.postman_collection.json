{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Skill Hub API",
    "description": "Fastify backend collection for providers, services, and jobs. Import it and set the `baseUrl` variable if needed.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "providerId", "value": "1" },
    { "key": "serviceId", "value": "1" },
    { "key": "jobId", "value": "" },
    { "key": "inputCommitment", "value": "0x1111111111111111111111111111111111111111111111111111111111111111" },
    { "key": "outputCommitment", "value": "0x2222222222222222222222222222222222222222222222222222222222222222" },
    { "key": "signatureExpiresAt", "value": "1893456000" },
    { "key": "providerSignature", "value": "0x" },
    { "key": "userSignature", "value": "0x" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Response: { \"ok\": true }"
          }
        }
      ]
    },
    {
      "name": "Providers",
      "item": [
        {
          "name": "List providers",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/providers"
          }
        },
        {
          "name": "Get provider",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/providers/{{providerId}}",
            "description": "Set `providerId` in the collection variables."
          }
        },
        {
          "name": "Create provider",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider_id\": \"{{providerId}}\",\n  \"name\": \"Demo Provider\",\n  \"description\": \"Optional description\",\n  \"owner_wallet\": \"0x0000000000000000000000000000000000000001\",\n  \"payout_wallet\": \"0x0000000000000000000000000000000000000002\",\n  \"api_base_url\": \"https://api.example.com\",\n  \"trust_level\": \"VERIFIED\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/providers"
          }
        },
        {
          "name": "Update provider",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated name\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/providers/{{providerId}}"
          }
        },
        {
          "name": "Delete provider",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/providers/{{providerId}}"
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "List services",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/services",
            "description": "Optional query parameters: ?provider_id=&status= (for example ACTIVE)."
          }
        },
        {
          "name": "Get service",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/services/{{serviceId}}"
          }
        },
        {
          "name": "Create service",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"service_id\": \"{{serviceId}}\",\n  \"provider_id\": \"{{providerId}}\",\n  \"name\": \"Text API\",\n  \"description\": \"Optional\",\n  \"service_type\": \"AI\",\n  \"endpoint_path\": \"/v1/process\",\n  \"input_schema\": { \"type\": \"object\" },\n  \"output_schema\": { \"type\": \"object\" },\n  \"price_usdc\": 1.5,\n  \"max_concurrent_jobs\": 2,\n  \"timeout_seconds\": 300,\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/services",
            "description": "Set `providerId` to an existing provider id."
          }
        },
        {
          "name": "Update service",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Renamed service\",\n  \"price_usdc\": 2.0\n}"
            },
            "url": "{{baseUrl}}/services/{{serviceId}}"
          }
        },
        {
          "name": "Delete service",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/services/{{serviceId}}"
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/jobs",
            "description": "Optional query parameters: ?user_wallet=&service_id=&status=."
          }
        },
        {
          "name": "Get job",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/jobs/{{jobId}}"
          }
        },
        {
          "name": "Create job",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_wallet\": \"0x00000000000000000000000000000000000000aa\",\n  \"service_id\": \"{{serviceId}}\",\n  \"input_uri\": \"ipfs://input\",\n  \"input_commitment\": \"{{inputCommitment}}\",\n  \"queue_timeout_seconds\": 3600,\n  \"authorization_expires_in_seconds\": 3600\n}"
            },
            "url": "{{baseUrl}}/jobs"
          }
        },
        {
          "name": "Start authorization request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expires_at\": {{signatureExpiresAt}}\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/start-authorization-request",
            "description": "Returns the EIP-712 typed data that the provider must sign for `startJob` and the unsigned `start_job_args`."
          }
        },
        {
          "name": "Start job args",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider_signature\": \"{{providerSignature}}\",\n  \"expires_at\": {{signatureExpiresAt}}\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/start-job",
            "description": "Returns the arguments for `startJob(jobId, expiresAt, providerSignature)`. `provider_signature` must come from signing the Start authorization request payload."
          }
        },
        {
          "name": "Job finish",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"output\": { \"result\": \"ok\" },\n  \"output_uri\": \"ipfs://output\",\n  \"output_commitment\": \"{{outputCommitment}}\",\n  \"expires_in_seconds\": 3600\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/job-finish",
            "description": "Called by the provider when the job is finished. The backend performs minimal output schema validation, signs and stores the DeliveryAttestation, then returns the settlement arguments. NoDeliveryAttestations are emitted automatically by the backend after `work_deadline`."
          }
        },
        {
          "name": "Acceptance request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"output_commitment\": \"{{outputCommitment}}\",\n  \"expires_at\": {{signatureExpiresAt}}\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/acceptance-request",
            "description": "Returns the EIP-712 typed data that the user must sign to accept the output. Use the same `signatureExpiresAt` value in the settlement request."
          }
        },
        {
          "name": "Settle with user signature args",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"output_commitment\": \"{{outputCommitment}}\",\n  \"user_signature\": \"{{userSignature}}\",\n  \"expires_at\": {{signatureExpiresAt}}\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/settle-with-user-signature",
            "description": "Returns the arguments for `settleWithUserSignature`. `expires_at` must match the value signed by the user."
          }
        },
        {
          "name": "Refund after queue timeout args",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/jobs/{{jobId}}/refund-after-queue-timeout",
            "description": "Returns the arguments for `refundAfterQueueTimeout` after the queue deadline has expired."
          }
        },
        {
          "name": "Refund after final timeout args",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/jobs/{{jobId}}/refund-after-final-timeout",
            "description": "Returns the arguments for `refundAfterFinalTimeout` after the final refund deadline has expired."
          }
        }
      ]
    }
  ]
}
