{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Skill Hub API",
    "description": "Fastify backend collection for wallet auth, providers and jobs. Import it and set the `baseUrl` variable if needed.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "authWalletAddress", "value": "" },
    { "key": "authPrivateKey", "value": "" },
    { "key": "authChainId", "value": "1" },
    { "key": "authChallengeId", "value": "" },
    { "key": "authDomain", "value": "localhost" },
    { "key": "authUri", "value": "http://localhost:3000" },
    { "key": "authNonce", "value": "" },
    { "key": "authIssuedAt", "value": "" },
    { "key": "authExpiresAt", "value": "" },
    { "key": "authStatement", "value": "Sign in to AgentHub." },
    { "key": "authSiweMessage", "value": "" },
    { "key": "authSiweSignature", "value": "" },
    { "key": "accessToken", "value": "" },
    { "key": "accessTokenExpiresIn", "value": "" },
    { "key": "providerId", "value": "1" },
    { "key": "jobId", "value": "" },
    { "key": "inputCommitment", "value": "0x1111111111111111111111111111111111111111111111111111111111111111" },
    { "key": "outputCommitment", "value": "0x2222222222222222222222222222222222222222222222222222222222222222" },
    { "key": "signatureExpiresAt", "value": "1893456000" },
    { "key": "providerSignature", "value": "0x" },
    { "key": "userSignature", "value": "0x" },
    { "key": "providerAddress", "value": "" },
    { "key": "providerPrivateKey", "value": "" },
    { "key": "providerRequestTimestamp", "value": "" },
    { "key": "providerRequestNonce", "value": "" },
    { "key": "providerRequestBodyHash", "value": "" },
    { "key": "providerRequestQueryHash", "value": "" },
    { "key": "providerRequestSignature", "value": "" },
    { "key": "providerRequestMessage", "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const providerAuthRoutes = [\"/start-next-job-request\", \"/start-job\", \"/job-finish\"];",
          "const requestUrl = pm.variables.replaceIn(pm.request.url.toString());",
          "const pathname = requestUrl.split(\"?\")[0];",
          "const isProviderAuthRoute = providerAuthRoutes.some((suffix) => pathname.endsWith(suffix));",
          "",
          "if (isProviderAuthRoute) {",
          "  const ethersPackage = pm.require(\"npm:ethers@6.16.0\");",
          "  const ethers = ethersPackage.ethers || ethersPackage;",
          "  const providerId = pm.variables.get(\"providerId\");",
          "  const privateKey = pm.variables.get(\"providerPrivateKey\");",
          "  if (!providerId) throw new Error(\"providerId collection variable is required for provider auth headers\");",
          "  if (!privateKey) throw new Error(\"providerPrivateKey collection variable is required to sign provider auth headers\");",
          "",
          "  const wallet = new ethers.Wallet(privateKey);",
          "  const configuredAddress = pm.variables.get(\"providerAddress\");",
          "  const providerAddress = ethers.getAddress(configuredAddress || wallet.address);",
          "  if (providerAddress !== wallet.address) throw new Error(\"providerAddress does not match providerPrivateKey\");",
          "",
          "  const rawBody = pm.request.body && pm.request.body.raw ? pm.variables.replaceIn(pm.request.body.raw) : \"\";",
          "  const rawQuery = requestUrl.includes(\"?\") ? requestUrl.slice(requestUrl.indexOf(\"?\") + 1) : \"\";",
          "  const timestamp = Math.floor(Date.now() / 1000).toString();",
          "  const nonce = pm.variables.replaceIn(\"{{$guid}}\");",
          "  const bodyHash = ethers.keccak256(ethers.toUtf8Bytes(rawBody));",
          "  const queryHash = ethers.keccak256(ethers.toUtf8Bytes(rawQuery));",
          "  const message = [",
          "    \"SkillHub Provider Request\",",
          "    `providerId:${providerId}`,",
          "    `providerAddress:${providerAddress}`,",
          "    `timestamp:${timestamp}`,",
          "    `nonce:${nonce}`,",
          "    `bodyHash:${bodyHash}`,",
          "    `queryHash:${queryHash}`",
          "  ].join(\"\\n\");",
          "  const signature = wallet.signingKey.sign(ethers.hashMessage(message)).serialized;",
          "",
          "  pm.collectionVariables.set(\"providerAddress\", providerAddress);",
          "  pm.collectionVariables.set(\"providerRequestTimestamp\", timestamp);",
          "  pm.collectionVariables.set(\"providerRequestNonce\", nonce);",
          "  pm.collectionVariables.set(\"providerRequestBodyHash\", bodyHash);",
          "  pm.collectionVariables.set(\"providerRequestQueryHash\", queryHash);",
          "  pm.collectionVariables.set(\"providerRequestSignature\", signature);",
          "  pm.collectionVariables.set(\"providerRequestMessage\", message);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Response: { \"ok\": true }"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Create wallet challenge",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"wallet_address\": \"{{authWalletAddress}}\",\n  \"chain_id\": {{authChainId}}\n}"
            },
            "url": "{{baseUrl}}/auth/wallet/challenge",
            "description": "Creates a SIWE challenge. Set `authWalletAddress` and `authChainId` first. The test script stores challenge fields into collection variables."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set(\"authChallengeId\", body.challenge_id);",
                  "  pm.collectionVariables.set(\"authWalletAddress\", body.wallet_address);",
                  "  pm.collectionVariables.set(\"authChainId\", String(body.chain_id));",
                  "  pm.collectionVariables.set(\"authDomain\", body.domain);",
                  "  pm.collectionVariables.set(\"authUri\", body.uri);",
                  "  pm.collectionVariables.set(\"authNonce\", body.nonce);",
                  "  pm.collectionVariables.set(\"authIssuedAt\", body.issued_at);",
                  "  pm.collectionVariables.set(\"authExpiresAt\", body.expires_at);",
                  "  pm.collectionVariables.set(\"authStatement\", body.statement);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Wallet login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"challenge_id\": \"{{authChallengeId}}\",\n  \"message\": \"\",\n  \"signature\": \"{{authSiweSignature}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/wallet/login",
            "description": "Verifies the SIWE signature, stores the HttpOnly refresh cookie, and returns an access token. If `authPrivateKey` is set, the pre-request script builds and signs `authSiweMessage`; otherwise paste `authSiweMessage` and `authSiweSignature` manually. Do not use a production private key in Postman."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const privateKey = pm.variables.get(\"authPrivateKey\");",
                  "let siweMessage = pm.variables.get(\"authSiweMessage\");",
                  "let siweSignature = pm.variables.get(\"authSiweSignature\");",
                  "if (privateKey) {",
                  "  const ethersPackage = pm.require(\"npm:ethers@6.16.0\");",
                  "  const ethers = ethersPackage.ethers || ethersPackage;",
                  "  const siwePackage = pm.require(\"npm:siwe@3.0.0\");",
                  "  const SiweMessage = siwePackage.SiweMessage;",
                  "  const wallet = new ethers.Wallet(privateKey);",
                  "  const walletAddress = ethers.getAddress(pm.variables.get(\"authWalletAddress\") || wallet.address);",
                  "  if (walletAddress !== wallet.address) throw new Error(\"authWalletAddress does not match authPrivateKey\");",
                  "  const message = new SiweMessage({",
                  "    domain: pm.variables.get(\"authDomain\"),",
                  "    address: walletAddress,",
                  "    statement: pm.variables.get(\"authStatement\"),",
                  "    uri: pm.variables.get(\"authUri\"),",
                  "    version: \"1\",",
                  "    chainId: Number(pm.variables.get(\"authChainId\")),",
                  "    nonce: pm.variables.get(\"authNonce\"),",
                  "    issuedAt: pm.variables.get(\"authIssuedAt\"),",
                  "    expirationTime: pm.variables.get(\"authExpiresAt\")",
                  "  });",
                  "  const preparedMessage = message.prepareMessage();",
                  "  const signature = wallet.signingKey.sign(ethers.hashMessage(preparedMessage)).serialized;",
                  "  siweMessage = preparedMessage;",
                  "  siweSignature = signature;",
                  "  pm.collectionVariables.set(\"authSiweMessage\", preparedMessage);",
                  "  pm.collectionVariables.set(\"authSiweSignature\", signature);",
                  "}",
                  "if (siweMessage && siweSignature) {",
                  "  pm.request.body.update(JSON.stringify({",
                  "    challenge_id: pm.variables.get(\"authChallengeId\"),",
                  "    message: siweMessage,",
                  "    signature: siweSignature",
                  "  }, null, 2));",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set(\"accessToken\", body.access_token);",
                  "  pm.collectionVariables.set(\"accessTokenExpiresIn\", String(body.expires_in));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh access token",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/refresh",
            "description": "Uses the `refresh_token` HttpOnly cookie set by Wallet login, rotates it, and stores the new access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set(\"accessToken\", body.access_token);",
                  "  pm.collectionVariables.set(\"accessTokenExpiresIn\", String(body.expires_in));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/logout",
            "description": "Revokes the current refresh-token session and clears the refresh cookie. Returns `{ \"ok\": true }` even if the cookie is absent or invalid."
          }
        },
        {
          "name": "Get me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/me",
            "description": "Protected route. Requires `accessToken` from Wallet login or Refresh access token."
          }
        }
      ]
    },
    {
      "name": "Providers",
      "item": [
        {
          "name": "List providers",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/providers"
          }
        },
        {
          "name": "Get provider",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/providers/{{providerId}}",
            "description": "Set `providerId` in the collection variables."
          }
        },
        {
          "name": "Create provider",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Provider\",\n  \"description\": \"Optional description\",\n  \"owner_wallet\": \"0x0000000000000000000000000000000000000001\",\n  \"payout_wallet\": \"0x0000000000000000000000000000000000000002\",\n  \"api_base_url\": \"https://api.example.com\",\n  \"trust_level\": \"VERIFIED\",\n  \"service_type\": \"AI\",\n  \"input_schema\": { \"type\": \"object\" },\n  \"output_schema\": { \"type\": \"object\" },\n  \"price_usdc\": 1.5,\n  \"max_concurrent_jobs\": 2,\n  \"timeout_seconds\": 300\n}"
            },
            "url": "{{baseUrl}}/providers"
          }
        },
        {
          "name": "Update provider",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated name\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/providers/{{providerId}}"
          }
        },
        {
          "name": "Delete provider",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/providers/{{providerId}}"
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/jobs",
            "description": "Optional query parameters: ?user_wallet=&provider_request_id=&status=."
          }
        },
        {
          "name": "Get job",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/jobs/{{jobId}}"
          }
        },
        {
          "name": "Create job",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_wallet\": \"0x00000000000000000000000000000000000000aa\",\n  \"provider_id\": \"{{providerId}}\",\n  \"input\": { \"prompt\": \"Do a poem about the weather\" },\n  \"input_commitment\": \"{{inputCommitment}}\",\n  \"queue_timeout_seconds\": 3600,\n  \"authorization_expires_in_seconds\": 3600\n}"
            },
            "url": "{{baseUrl}}/jobs"
          }
        },
        {
          "name": "Start next job request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Provider-Id", "value": "{{providerId}}" },
              { "key": "X-Provider-Address", "value": "{{providerAddress}}" },
              { "key": "X-Timestamp", "value": "{{providerRequestTimestamp}}" },
              { "key": "X-Body-Hash", "value": "{{providerRequestBodyHash}}" },
              { "key": "X-Signature", "value": "{{providerRequestSignature}}" },
              { "key": "X-Nonce", "value": "{{providerRequestNonce}}" },
              { "key": "X-Query-Hash", "value": "{{providerRequestQueryHash}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expires_at\": {{signatureExpiresAt}}\n}"
            },
            "url": "{{baseUrl}}/jobs/start-next-job-request",
            "description": "Returns the EIP-712 typed data that the provider must sign for `startJob` for its next funded job. The backend derives the provider from the signed headers and selects the smallest on-chain `job_id` for that provider."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.start_job_args && body.start_job_args.job_id) {",
                  "    pm.collectionVariables.set(\"jobId\", body.start_job_args.job_id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Start job args",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Provider-Id", "value": "{{providerId}}" },
              { "key": "X-Provider-Address", "value": "{{providerAddress}}" },
              { "key": "X-Timestamp", "value": "{{providerRequestTimestamp}}" },
              { "key": "X-Body-Hash", "value": "{{providerRequestBodyHash}}" },
              { "key": "X-Signature", "value": "{{providerRequestSignature}}" },
              { "key": "X-Nonce", "value": "{{providerRequestNonce}}" },
              { "key": "X-Query-Hash", "value": "{{providerRequestQueryHash}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider_signature\": \"{{providerSignature}}\",\n  \"expires_at\": {{signatureExpiresAt}}\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/start-job",
            "description": "Relays `startJob(jobId, expiresAt, providerSignature)` and returns the job `input` plus transaction metadata. `provider_signature` must come from signing the Start authorization request payload."
          }
        },
        {
          "name": "Job finish",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Provider-Id", "value": "{{providerId}}" },
              { "key": "X-Provider-Address", "value": "{{providerAddress}}" },
              { "key": "X-Timestamp", "value": "{{providerRequestTimestamp}}" },
              { "key": "X-Body-Hash", "value": "{{providerRequestBodyHash}}" },
              { "key": "X-Signature", "value": "{{providerRequestSignature}}" },
              { "key": "X-Nonce", "value": "{{providerRequestNonce}}" },
              { "key": "X-Query-Hash", "value": "{{providerRequestQueryHash}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"output\": { \"result\": \"ok\", \"uri\": \"ipfs://output\" },\n  \"output_commitment\": \"{{outputCommitment}}\",\n  \"expires_in_seconds\": 3600\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/job-finish",
            "description": "Called by the provider when the job is finished. The backend performs minimal output schema validation, signs and stores the DeliveryAttestation, then returns the settlement arguments. NoDeliveryAttestations are emitted automatically by the backend after `work_deadline`."
          }
        },
        {
          "name": "Acceptance request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"output_commitment\": \"{{outputCommitment}}\",\n  \"expires_at\": {{signatureExpiresAt}}\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/acceptance-request",
            "description": "Step 1 for user acceptance. Returns the EIP-712 `JobAcceptance` typed data that the user wallet must sign. Copy the resulting signature into `userSignature`, then call `POST {{baseUrl}}/jobs/{{jobId}}/acceptance` with the same output commitment and `expires_at`."
          }
        },
        {
          "name": "Acceptance",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"output_commitment\": \"{{outputCommitment}}\",\n  \"expires_at\": {{signatureExpiresAt}},\n  \"user_signature\": \"{{userSignature}}\"\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/acceptance",
            "description": "Step 2 for user acceptance. Submit the EIP-712 signature produced from `POST {{baseUrl}}/jobs/{{jobId}}/acceptance-request`; the backend relays `settleWithUserSignature` and settles the job."
          }
        },
        {
          "name": "Refund after queue timeout args",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/jobs/{{jobId}}/refund-after-queue-timeout",
            "description": "Returns the arguments for `refundAfterQueueTimeout` after the queue deadline has expired."
          }
        },
        {
          "name": "Refund after final timeout args",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/jobs/{{jobId}}/refund-after-final-timeout",
            "description": "Returns the arguments for `refundAfterFinalTimeout` after the final refund deadline has expired."
          }
        }
      ]
    }
  ]
}
