{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Skill Hub API",
    "description": "Fastify backend collection for providers, services, jobs, and escrows. Import it and set the `baseUrl` variable if needed.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "providerId", "value": "1" },
    { "key": "serviceId", "value": "1" },
    { "key": "jobId", "value": "" },
    { "key": "onchainJobId", "value": "1" },
    { "key": "inputCommitment", "value": "0x1111111111111111111111111111111111111111111111111111111111111111" },
    { "key": "outputCommitment", "value": "0x2222222222222222222222222222222222222222222222222222222222222222" },
    { "key": "signatureExpiresAt", "value": "1893456000" },
    { "key": "providerSignature", "value": "0x" },
    { "key": "userSignature", "value": "0x" },
    { "key": "escrowId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health",
            "description": "Response: { \"ok\": true }"
          }
        }
      ]
    },
    {
      "name": "Providers",
      "item": [
        {
          "name": "List providers",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/providers"
          }
        },
        {
          "name": "Get provider",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/providers/{{providerId}}",
            "description": "Set `providerId` in the collection variables."
          }
        },
        {
          "name": "Create provider",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider_id\": \"{{providerId}}\",\n  \"name\": \"Demo Provider\",\n  \"description\": \"Optional description\",\n  \"owner_wallet\": \"0x0000000000000000000000000000000000000001\",\n  \"payout_wallet\": \"0x0000000000000000000000000000000000000002\",\n  \"api_base_url\": \"https://api.example.com\",\n  \"trust_level\": \"VERIFIED\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/providers"
          }
        },
        {
          "name": "Update provider",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated name\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/providers/{{providerId}}"
          }
        },
        {
          "name": "Delete provider",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/providers/{{providerId}}"
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "List services",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/services",
            "description": "Optional query parameters: ?provider_id=&status= (for example ACTIVE)."
          }
        },
        {
          "name": "Get service",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/services/{{serviceId}}"
          }
        },
        {
          "name": "Create service",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"service_id\": \"{{serviceId}}\",\n  \"provider_id\": \"{{providerId}}\",\n  \"name\": \"Text API\",\n  \"description\": \"Optional\",\n  \"service_type\": \"AI\",\n  \"endpoint_path\": \"/v1/process\",\n  \"input_schema\": { \"type\": \"object\" },\n  \"output_schema\": { \"type\": \"object\" },\n  \"price_usdc\": 1.5,\n  \"max_concurrent_jobs\": 2,\n  \"timeout_seconds\": 300,\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{baseUrl}}/services",
            "description": "Set `providerId` to an existing provider id."
          }
        },
        {
          "name": "Update service",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Renamed service\",\n  \"price_usdc\": 2.0\n}"
            },
            "url": "{{baseUrl}}/services/{{serviceId}}"
          }
        },
        {
          "name": "Delete service",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/services/{{serviceId}}"
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/jobs",
            "description": "Optional query parameters: ?user_wallet=&service_id=&status=."
          }
        },
        {
          "name": "Get job",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/jobs/{{jobId}}"
          }
        },
        {
          "name": "Create job",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_wallet\": \"0x00000000000000000000000000000000000000aa\",\n  \"service_id\": \"{{serviceId}}\",\n  \"input_uri\": \"ipfs://input\",\n  \"input_commitment\": \"{{inputCommitment}}\",\n  \"queue_timeout_seconds\": 3600,\n  \"authorization_expires_in_seconds\": 3600\n}"
            },
            "url": "{{baseUrl}}/jobs"
          }
        },
        {
          "name": "Link on-chain job id",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"job_id\": \"{{onchainJobId}}\"\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/onchain-job",
            "description": "`jobId` can be the backend `request_id`. `onchainJobId` is the job id emitted by the escrow contract."
          }
        },
        {
          "name": "Start authorization request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expires_at\": {{signatureExpiresAt}}\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/start-authorization-request",
            "description": "Returns the EIP-712 typed data that the provider must sign for `startJob` and the unsigned `start_job_args`."
          }
        },
        {
          "name": "Start job args",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider_signature\": \"{{providerSignature}}\",\n  \"expires_at\": {{signatureExpiresAt}}\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/start-job",
            "description": "Returns the arguments for `startJob(jobId, expiresAt, providerSignature)`. `provider_signature` must come from signing the Start authorization request payload."
          }
        },
        {
          "name": "Delivery attestation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"output_uri\": \"ipfs://output\",\n  \"output_commitment\": \"{{outputCommitment}}\",\n  \"expires_in_seconds\": 3600\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/delivery-attestation",
            "description": "Signs the delivery attestation. If `output_commitment` is omitted, the backend derives a commitment from `output_hash` or `output_uri`."
          }
        },
        {
          "name": "No delivery attestation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expires_in_seconds\": 3600\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/no-delivery-attestation",
            "description": "Call this after `work_deadline` if the provider did not deliver. Returns the arguments for `refundWithNoDeliveryAttestation`."
          }
        },
        {
          "name": "Acceptance request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"output_commitment\": \"{{outputCommitment}}\",\n  \"expires_at\": {{signatureExpiresAt}}\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/acceptance-request",
            "description": "Returns the EIP-712 typed data that the user must sign to accept the output. Use the same `signatureExpiresAt` value in the settlement request."
          }
        },
        {
          "name": "Settle with user signature args",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"output_commitment\": \"{{outputCommitment}}\",\n  \"user_signature\": \"{{userSignature}}\",\n  \"expires_at\": {{signatureExpiresAt}}\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/settle-with-user-signature",
            "description": "Returns the arguments for `settleWithUserSignature`. `expires_at` must match the value signed by the user."
          }
        },
        {
          "name": "Refund after queue timeout args",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/jobs/{{jobId}}/refund-after-queue-timeout",
            "description": "Returns the arguments for `refundAfterQueueTimeout` after the queue deadline has expired."
          }
        },
        {
          "name": "Refund after final timeout args",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/jobs/{{jobId}}/refund-after-final-timeout",
            "description": "Returns the arguments for `refundAfterFinalTimeout` after the final refund deadline has expired."
          }
        },
        {
          "name": "Patch job status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"FUNDED\",\n  \"output_uri\": null,\n  \"output_hash\": null,\n  \"error_message\": null\n}"
            },
            "url": "{{baseUrl}}/jobs/{{jobId}}/status",
            "description": "Set `status` according to the allowed backend transitions."
          }
        }
      ]
    },
    {
      "name": "Escrows",
      "item": [
        {
          "name": "Get escrow by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/escrows/{{escrowId}}"
          }
        },
        {
          "name": "Get escrow by job",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/jobs/{{jobId}}/escrow"
          }
        },
        {
          "name": "Create escrow",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"request_id\": \"{{jobId}}\",\n  \"chain_id\": 1,\n  \"token_address\": \"0x0000000000000000000000000000000000000000\",\n  \"escrow_contract\": \"0x0000000000000000000000000000000000000000\",\n  \"amount_usdc\": 10,\n  \"platform_fee_usdc\": 0.5,\n  \"provider_payout_usdc\": 9.5\n}"
            },
            "url": "{{baseUrl}}/escrows"
          }
        },
        {
          "name": "Fund escrow",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fund_tx_hash\": \"0xabc\"\n}"
            },
            "url": "{{baseUrl}}/escrows/{{escrowId}}/fund"
          }
        },
        {
          "name": "Release escrow",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"release_tx_hash\": \"0xdef\"\n}"
            },
            "url": "{{baseUrl}}/escrows/{{escrowId}}/release"
          }
        },
        {
          "name": "Refund escrow",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refund_tx_hash\": \"0x789\"\n}"
            },
            "url": "{{baseUrl}}/escrows/{{escrowId}}/refund"
          }
        },
        {
          "name": "Dispute escrow",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{baseUrl}}/escrows/{{escrowId}}/dispute",
            "description": "The API ignores the body; it is present only so Postman sends a valid request body."
          }
        }
      ]
    }
  ]
}
