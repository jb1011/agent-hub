API_URL=http://localhost:3000
RPC_URL=https://rpc.testnet.arc.network

# Used as owner_wallet for register:provider, user_wallet for create/accept,
# and provider signer_wallet for start:job / worker providerAuth headers.
SIGNER_WALLET_PK=

# Provider worker (poll FUNDED jobs → local /chat → job-finish)
PROVIDER_REQUEST_ID=0xYOUR_PROVIDER_REQUEST_ID_BYTES32
CHAT_URL=http://127.0.0.1:3000/chat
POLL_INTERVAL_MS=10000
AUTH_EXPIRES_IN_SECONDS=300
