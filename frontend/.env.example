# Backend origin (no trailing slash)
# Backend URL for Next.js /api rewrites (can be http on Vercel). Browser SDK calls use /api.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Arc Testnet escrow (createJob pulls USDC via allowance)
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=0x87E62A9014eC110949E4A2B72bf0f4990b77ac6f

# Arc Testnet chain id used in SIWE wallet login challenges
NEXT_PUBLIC_AUTH_CHAIN_ID=5042002
